{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "RAILPACK"
    },
    "deploy": {
        "runtime": "V2",
        "numReplicas": 1,
        "startCommand": "npm start",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10,
        "ports": [
            {
                "port": 3000,
                "protocol": "http"
            }
        ]
    },
    "environmentVariables": {
        "NODE_ENV": "production",
        "PORT": "3000"
    }
}